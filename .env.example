# USDA FoodData Central — https://fdc.nal.usda.gov/api-guide.html
# Free account, used for macro lookup per ingredient
USDA_API_KEY=your_usda_api_key_here

# Anthropic Claude API — https://console.anthropic.com/
# Used for fallback recipe generation when TheMealDB has no good match
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Kroger Developer API — https://developer.kroger.com/
# Used for real-time local grocery pricing by zip code
# Two environments available:
#   Certification: https://api-ce.kroger.com/v1  (dev/test — limited inventory, prices often $0.00)
#   Production:    https://api.kroger.com/v1      (live — requires Kroger production approval)
# Paste certification OR production credentials here depending on your stage.
# Also update KROGER_BASE in src/modules/pricing.py to match.
KROGER_CLIENT_ID=your_kroger_client_id_here
KROGER_CLIENT_SECRET=your_kroger_client_secret_here
